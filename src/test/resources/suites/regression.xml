<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="RegressionSuite" verbose="1" parallel="false">

    <!-- API Regression dipisah per feature -->
    <test name="Login API Tests">
        <classes>
            <class name="api.auth.LoginTest"/>
        </classes>
    </test>

    <test name="User API Tests">
        <classes>
            <class name="api.users.CreateUserTest"/>
            <class name="api.users.SendVerificationTokenTest"/>
            <class name="api.users.VerifyTokenTest"/>
        </classes>
    </test>

    <!-- UI Regression (pakai yang sudah aman jalan) -->
    <test name="Login UI Tests">
        <classes>
            <class name="tests.LoginTest"/>
        </classes>
    </test>

    <test name="Register UI Tests">
        <classes>
            <class name="tests.RegisterTest"/>
        </classes>
    </test>

    <test name="Reset Password UI Tests">
        <classes>
            <class name="tests.ResetPasswordTest"/>
        </classes>
    </test>

    <!-- Listener untuk logging/report -->
    <listeners>
        <listener class-name="io.qameta.allure.testng.AllureTestNg"/>
        <listener class-name="core.TestListener"/>
    </listeners>

</suite>
