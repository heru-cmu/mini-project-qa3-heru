<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Regression Suite" verbose="1" parallel="false">

    <test name="Login Tests">
        <classes>
            <class name="tests.LoginTest"/>
        </classes>
    </test>

    <test name="Register Tests">
        <classes>
            <class name="tests.RegisterTest"/>
        </classes>
    </test>

    <test name="Reset Password Tests">
        <classes>
            <class name="tests.ResetPasswordTest"/>
        </classes>
    </test>

    <listeners>
        <listener class-name="core.TestListener"/>
    </listeners>


</suite>
